&lt;script&gt;
let R0;

function setup() {
  createCanvas(1000, 1000);
}

function draw() {
  background(0);
  R0 = 0.26 * width;
  if (R0 &lt;= 0)
    noLoop();
  translate(width/2, width/2);
  let inc = .005;
  noStroke();
  
for (let i=0; R0 &gt; 20; i++) {
	R0 -= 10;
	fill(255 * (i % 2));
	beginShape();
	for (let a = 0; a &lt;= TWO_PI; a += inc) {
		let r - min(1 / abs(sin(a)), 1 / abs(cos(a)));
		let f = 2;
		let R = R0 + noise((1 + sin(a)) * f, (1 + cos(a)) * f) * R0;
		let x = R * r * sin(a);
		let y = R * r * cos(a);
		vertex(x, y);
	}
	endShape(CLOSE);
	
}
}
&lt;/script&gt;</content><author><name></name></author><category term="creative code" /><category term="random," /><category term="fail" /><summary type="html">from this instagram, but I don't think it works.</summary></entry><entry><title type="html">html experiments</title><link href="http://127.0.0.1:4000/html/" rel="alternate" type="text/html" title="html experiments" /><published>2020-10-28T00:00:00-04:00</published><updated>2020-10-28T00:00:00-04:00</updated><id>http://127.0.0.1:4000/html</id><content type="html" xml:base="http://127.0.0.1:4000/html/">coisas a fazer
